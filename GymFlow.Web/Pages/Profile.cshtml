@page
@model ProfileModel
@{
    ViewData["Title"] = Model.IsCoach ? "پروفایل مربی" : "پروفایل من";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@(Model.IsCoach ? "👤 پروفایل مربی" : "👤 پروفایل من")</h2>
        <a href="/" class="btn btn-secondary">بازگشت به داشبورد</a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">ویرایش اطلاعات</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <!-- اطلاعات شخصی (مشترک) -->
                        <h5 class="border-bottom pb-2 mb-3">📋 اطلاعات شخصی</h5>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">نام</label>
                                <input type="text" class="form-control" asp-for="FirstName" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">نام خانوادگی</label>
                                <input type="text" class="form-control" asp-for="LastName" required />
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label">ایمیل</label>
                                <input type="email" class="form-control" asp-for="Email" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">تلفن</label>
                                <input type="tel" class="form-control" asp-for="Phone" />
                            </div>
                        </div>

                        @if (Model.IsCoach)
                        {
                            <!-- اطلاعات حرفه‌ای (فقط مربی) -->
                            <h5 class="border-bottom pb-2 mb-3 mt-4">💼 اطلاعات حرفه‌ای</h5>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">تخصص</label>
                                    <input type="text" class="form-control" asp-for="Specialization" required />
                                    <small class="text-muted">مثلاً بدنسازی، فیتنس، پاورلیفتینگ، یوگا، تغذیه، کاهش وزن</small>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">سال‌های تجربه</label>
                                    <input type="number" class="form-control" asp-for="YearsOfExperience" min="0" max="50" required />
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- اطلاعات بدنسازی (فقط کاربر عادی) -->
                            <h5 class="border-bottom pb-2 mb-3 mt-4">💪 اطلاعات تناسب اندام</h5>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">هدف تمرینی</label>
                                    <select class="form-select" asp-for="Goal">
                                        <option value="0">کاهش چربی</option>
                                        <option value="1">افزایش عضله</option>
                                        <option value="2">تناسب اندام</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">وزن (کیلوگرم)</label>
                                    <input type="number" step="0.1" class="form-control" asp-for="Weight" min="20" max="300" />
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">قد (سانتی‌متر)</label>
                                    <input type="number" step="0.1" class="form-control" asp-for="Height" min="100" max="250" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">تیپ بدنی</label>
                                    <select class="form-select" asp-for="BodyType">
                                        <option value="">انتخاب کنید...</option>
                                        <option value="0">تناسب</option>
                                        <option value="1">لاغر عضلانی</option>
                                        <option value="2">چاق</option>
                                        <option value="3">چاق عضلانی</option>
                                        <option value="4">اضافه وزن</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label class="form-label">کالری مصرفی تخمینی (در روز)</label>
                                    <input type="number" class="form-control" asp-for="EstimatedCaloriesIntake" min="1000" max="5000" />
                                </div>
                                <div class="col-md-6">
                                    <div class="form-check mt-4">
                                        <input class="form-check-input" type="checkbox" asp-for="IsCompetitive" />
                                        <label class="form-check-label">ورزشکار حرفه‌ای (رقابتی)</label>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- انتخاب مربی -->
                            <div class="row mb-3">
                                <div class="col-md-12">
                                    <label class="form-label">👨‍🏫 مربی</label>
                                    <select class="form-select" asp-for="SelectedCoachId">
                                        <option value="">-- بدون مربی --</option>
                                        @foreach (var coach in Model.CoachesList)
                                        {
                                            <option value="@coach.Id">@coach.FullName - @coach.Specialization</option>
                                        }
                                    </select>
                                    <small class="text-muted">می‌توانید یک مربی برای راهنمایی انتخاب کنید</small>
                                </div>
                            </div>
                        }

                        <!-- اطلاعات فقط خواندنی -->
                        <h5 class="border-bottom pb-2 mb-3 mt-4">ℹ️ اطلاعات حساب</h5>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label">نام کاربری</label>
                                <input type="text" class="form-control" asp-for="Username" readonly disabled />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">نقش</label>
                                <input type="text" class="form-control" value="@(Model.IsCoach ? "مربی" : "کاربر عادی")" readonly disabled />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">تاریخ عضویت</label>
                                <input type="text" class="form-control" asp-for="CreatedAt" readonly disabled />
                            </div>
                        </div>

                        <hr />
                        <button type="submit" class="btn btn-primary w-100">💾 ذخیره تغییرات</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- المنت‌های مخفی برای نمایش Toast -->
@if (TempData["Message"] != null)
{
    <input type="hidden" id="toastMessage" value="@TempData["Message"]" />
    <input type="hidden" id="toastTitle" value="موفقیت ✅" />
    <input type="hidden" id="toastIsError" value="false" />
}
@if (TempData["ErrorMessage"] != null)
{
    <input type="hidden" id="toastMessage" value="@TempData["ErrorMessage"]" />
    <input type="hidden" id="toastTitle" value="خطا ❌" />
    <input type="hidden" id="toastIsError" value="true" />
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var messageElem = document.getElementById('toastMessage');
            if (messageElem && messageElem.value) {
                var titleElem = document.getElementById('toastTitle');
                var isErrorElem = document.getElementById('toastIsError');
                var title = titleElem ? titleElem.value : "اطلاعیه";
                var isError = isErrorElem ? isErrorElem.value === 'true' : false;
                
                if (typeof showToast === 'function') {
                    showToast(messageElem.value, title, isError);
                }
            }
        });
    </script>
}