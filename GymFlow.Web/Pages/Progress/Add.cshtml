@page
@model AddModel
@{
    ViewData["Title"] = "ثبت وزن جدید";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0"><i class="fas fa-weight-scale"></i> ثبت وزن جدید</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">تاریخ</label>
                        <input type="date" class="form-control" asp-for="LogDate" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">وزن (کیلوگرم)</label>
                        <input type="number" step="0.1" class="form-control" asp-for="Weight" min="20" max="300" required />
                        <small class="text-muted">حداقل ۲۰، حداکثر ۳۰۰ کیلوگرم</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">درصد چربی بدن (اختیاری)</label>
                        <input type="number" step="0.1" class="form-control" asp-for="BodyFatPercentage" min="3" max="50" />
                        <small class="text-muted">حداقل ۳٪، حداکثر ۵۰٪</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">توضیحات</label>
                        <textarea class="form-control" asp-for="Notes" rows="3"></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-save"></i> ذخیره وزن</button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- المنت‌های مخفی برای نمایش Toast -->
@if (TempData["Message"] != null)
{
    <input type="hidden" id="toastMessage" value="@TempData["Message"]" />
    <input type="hidden" id="toastTitle" value="موفقیت ✅" />
    <input type="hidden" id="toastIsError" value="false" />
}
@if (TempData["ErrorMessage"] != null)
{
    <input type="hidden" id="toastMessage" value="@TempData["ErrorMessage"]" />
    <input type="hidden" id="toastTitle" value="خطا ❌" />
    <input type="hidden" id="toastIsError" value="true" />
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var messageElem = document.getElementById('toastMessage');
            if (messageElem && messageElem.value) {
                var titleElem = document.getElementById('toastTitle');
                var isErrorElem = document.getElementById('toastIsError');
                var title = titleElem ? titleElem.value : "اطلاعیه";
                var isError = isErrorElem ? isErrorElem.value === 'true' : false;
                
                if (typeof showToast === 'function') {
                    showToast(messageElem.value, title, isError);
                } else {
                    console.log('Toast: ' + messageElem.value);
                }
            }
        });
    </script>
}