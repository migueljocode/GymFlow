@page
@model IndexModel
@{
    ViewData["Title"] = "تاریخچه وزن";
}

<div class="container">
    @if (Model.IsCoach && Model.ClientId.HasValue)
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="mb-0">📊 تاریخچه وزن</h2>
            <a href="/Coach/Clients" class="btn btn-secondary">← بازگشت به لیست مشتریان</a>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div></div>
            <h2 class="mb-0">📊 تاریخچه وزن</h2>
            @if (!Model.IsCoach)
            {
                <a href="/Progress/Add" class="btn btn-primary">+ ثبت وزن جدید</a>
            }
            else
            {
                <div></div>
            }
        </div>
    }

    @if (!Model.WeightHistory.Any())
    {
        <div class="alert alert-info text-center">
            <p>هنوز وزنی ثبت نشده!</p>
            @if (!Model.IsCoach)
            {
                <a href="/Progress/Add" class="btn btn-primary">ثبت اولین وزن</a>
            }
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">جدول روند وزنی</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered text-center">
                                <thead class="table-dark">
                                    <tr>
                                        <th>تاریخ</th>
                                        <th>وزن (kg)</th>
                                        <th>درصد چربی</th>
                                        <th>تغییر نسبت به قبلی</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.WeightHistory.Count; i++)
                                    {
                                        var item = Model.WeightHistory[i];
                                        var change = i < Model.WeightHistory.Count - 1 ? item.Weight - Model.WeightHistory[i + 1].Weight : 0;
                                        var changeClass = change < 0 ? "text-success" : change > 0 ? "text-danger" : "text-muted";
                                        var changeSign = change > 0 ? "+" : "";
                                        <tr>
                                            <td>@item.LogDate.ToString("yyyy/MM/dd")</td>
                                            <td><strong>@item.Weight.ToString("F1")</strong></td>
                                            <td>@(item.BodyFatPercentage?.ToString("F1") ?? "-")</td>
                                            <td class="@changeClass">
                                                @if (i < Model.WeightHistory.Count - 1)
                                                {
                                                    @($"{changeSign}{change:F1}")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="alert alert-info mt-3">
                            <strong>📊 خلاصه کلی:</strong><br />
                            از <strong>@Model.FirstWeight.ToString("F1") kg</strong> به <strong>@Model.CurrentWeight.ToString("F1") kg</strong><br />
                            <span class="@(Model.TotalChange < 0 ? "text-success" : "text-danger")">
                                تغییر کل: @(Model.TotalChange > 0 ? "+" : "")@Model.TotalChange.ToString("F1") kg
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- المنت‌های مخفی برای نمایش Toast -->
@if (TempData["Message"] != null)
{
    <input type="hidden" id="toastMessage" value="@TempData["Message"]" />
    <input type="hidden" id="toastTitle" value="موفقیت ✅" />
    <input type="hidden" id="toastIsError" value="false" />
}
@if (TempData["ErrorMessage"] != null)
{
    <input type="hidden" id="toastMessage" value="@TempData["ErrorMessage"]" />
    <input type="hidden" id="toastTitle" value="خطا ❌" />
    <input type="hidden" id="toastIsError" value="true" />
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var messageElem = document.getElementById('toastMessage');
            if (messageElem && messageElem.value) {
                var titleElem = document.getElementById('toastTitle');
                var isErrorElem = document.getElementById('toastIsError');
                var title = titleElem ? titleElem.value : "اطلاعیه";
                var isError = isErrorElem ? isErrorElem.value === 'true' : false;
                
                if (typeof showToast === 'function') {
                    showToast(messageElem.value, title, isError);
                }
            }
        });
    </script>
}