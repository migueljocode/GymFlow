@page
@model DetailsModel
@{
    ViewData["Title"] = $"برنامه فاز {Model.Plan?.Phase}";
}

@functions {
    string GetMuscleGroupName(int muscles)
    {
        var names = new List<string>();
        if ((muscles & 1) != 0) names.Add("Chest");
        if ((muscles & 2) != 0) names.Add("Back");
        if ((muscles & 4) != 0) names.Add("Legs");
        if ((muscles & 8) != 0) names.Add("Shoulders");
        if ((muscles & 16) != 0) names.Add("Arms");
        if ((muscles & 32) != 0) names.Add("Core");
        return names.Count > 0 ? string.Join(", ", names) : "Full Body";
    }
    
    string GetIntensityName(int intensity)
    {
        return intensity switch
        {
            0 => "کم",
            1 => "متوسط",
            2 => "زیاد",
            _ => "نامشخص"
        };
    }
}

@if (Model.Plan == null)
{
    <div class="alert alert-danger text-center">
        <h4>برنامه تمرینی یافت نشد!</h4>
        <a href="/WorkoutPlans" class="btn btn-primary mt-3">بازگشت به لیست برنامه‌ها</a>
    </div>
}
else
{
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>📋 برنامه فاز @Model.Plan.Phase</h2>
            <div>
                <!-- تغییر: استفاده از فرم POST به جای لینک مستقیم -->
                <form method="post" asp-page-handler="DownloadPdf" asp-route-planId="@Model.Plan.Id" style="display:inline">
                    <button type="submit" class="btn btn-danger">
                        📄 دانلود PDF
                    </button>
                </form>
                <a href="/WorkoutPlans" class="btn btn-secondary ms-2">بازگشت</a>
            </div>
        </div>

        <!-- بقیه کد همان保持不变 -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h6 class="text-muted">تعداد جلسات در هفته</h6>
                        <h3 class="text-primary">@Model.Plan.SessionsPerWeek</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h6 class="text-muted">تاریخ شروع</h6>
                        <h3 class="text-primary">@Model.Plan.StartDate.ToString("yyyy/MM/dd")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h6 class="text-muted">تاریخ پایان</h6>
                        <h3 class="text-primary">@(Model.Plan.EndDate?.ToString("yyyy/MM/dd") ?? "در جریان")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center shadow-sm">
                    <div class="card-body">
                        <h6 class="text-muted">وضعیت</h6>
                        @if (Model.Plan.IsActive)
                        {
                            <h3 class="text-success">فعال 🔥</h3>
                        }
                        else
                        {
                            <h3 class="text-secondary">غیرفعال</h3>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">📊 پیشرفت برنامه</h5>
                    </div>
                    <div class="card-body">
                        <div class="progress mb-3" style="height: 25px;">
                            <div class="progress-bar bg-success" role="progressbar" 
                                 style="width: @Model.CompletionPercentage%;" 
                                 aria-valuenow="@Model.CompletionPercentage" aria-valuemin="0" aria-valuemax="100">
                                @Model.CompletionPercentage%
                            </div>
                        </div>
                        <p class="text-center">
                            <strong>@Model.CompletedSessions</strong> از <strong>@Model.TotalSessions</strong> جلسه تکمیل شده
                        </p>
                    </div>
                </div>
            </div>
        </div>

        @foreach (var day in Model.Plan.WorkoutDays.OrderBy(d => d.DayOfWeek))
        {
            <div class="card mb-4 shadow-sm">
                <div class="card-header bg-primary text-white">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">📅 @day.DayOfWeek</h4>
                        <span class="badge bg-light text-dark">@GetIntensityName(day.Intensity)</span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p><strong>🎯 عضلات هدف:</strong> @GetMuscleGroupName(day.TargetMuscles)</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong>⏱️ مدت زمان:</strong> @day.DurationMinutes دقیقه</p>
                        </div>
                    </div>
                    
                    @if (day.Exercises != null && day.Exercises.Any())
                    {
                        <h5 class="mt-3">🏋️ حرکات تمرینی:</h5>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>#</th>
                                        <th>نام حرکت</th>
                                        <th>عضله هدف</th>
                                        <th>ست</th>
                                        <th>تکرار</th>
                                        <th>استراحت</th>
                                        <th>توضیحات</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int index = 1;
                                        foreach (var ex in day.Exercises)
                                        {
                                            <tr>
                                                <td>@index</td>
                                                <td><strong>@ex.ExerciseName</strong></td>
                                                <td>@ex.MuscleGroup</td>
                                                <td>@ex.Sets</td>
                                                <td>@ex.Reps</td>
                                                <td>@ex.RestSeconds ثانیه</td>
                                                <td>@(string.IsNullOrEmpty(ex.Notes) ? "-" : ex.Notes)</td>
                                            </tr>
                                            index++;
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <p class="mb-0">⚠️ هنوز حرکتی برای این روز ثبت نشده است.</p>
                        </div>
                    }
                    
                    @if (!string.IsNullOrEmpty(day.Notes))
                    {
                        <div class="alert alert-secondary mt-3">
                            <strong>📝 یادداشت روز:</strong> @day.Notes
                        </div>
                    }
                </div>
            </div>
        }
        
        <div class="text-center mt-4 mb-5">
            <a href="/Workout/Log" class="btn btn-success btn-lg">
                ✅ ثبت تمرین امروز
            </a>
        </div>
    </div>
}