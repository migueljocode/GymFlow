@page
@model CreateModel
@{
    ViewData["Title"] = "ایجاد برنامه تمرینی جدید";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>➕ ایجاد برنامه تمرینی جدید</h2>
        <a href="/WorkoutPlans" class="btn btn-secondary">بازگشت</a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">اطلاعات برنامه تمرینی</h5>
                </div>
                <div class="card-body">
                    <form id="createPlanForm" method="post">
                        <div class="mb-3">
                            <label class="form-label">فاز برنامه</label>
                            <input type="number" class="form-control" asp-for="Phase" readonly disabled style="background-color:#e9ecef" />
                            <small class="form-text text-muted">فاز به صورت خودکار بر اساس برنامه‌های قبلی تعیین می‌شود</small>
                            <input type="hidden" asp-for="Phase" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">تعداد جلسات در هفته</label>
                            <select class="form-select" asp-for="SessionsPerWeek" id="sessionsPerWeek">
                                <option value="3">۳ جلسه</option>
                                <option value="4">۴ جلسه</option>
                                <option value="5">۵ جلسه</option>
                                <option value="6">۶ جلسه</option>
                            </select>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">تاریخ شروع</label>
                            <input type="date" class="form-control" asp-for="StartDate" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">تاریخ پایان (اختیاری)</label>
                            <input type="date" class="form-control" asp-for="EndDate" />
                            <small class="form-text text-muted">اگر خالی بگذارید، برنامه نامحدود خواهد بود</small>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">توضیحات (اختیاری)</label>
                            <textarea class="form-control" asp-for="Notes" rows="3"></textarea>
                        </div>
                        
                        <hr />
                        <h5 class="mt-3">🗓️ روزهای تمرینی</h5>
                        <p class="text-muted">روزهایی که می‌خواهید تمرین کنید را انتخاب کنید <span id="selectedCount" class="badge bg-danger">0</span> از <span id="maxSelect">3</span> روز</p>
                        
                        <div class="row">
                            @foreach (var day in Model.AvailableDays)
                            {
                                <div class="col-md-4 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input day-checkbox" type="checkbox" 
                                               name="SelectedDays" value="@day.Value" 
                                               id="day_@day.Value" />
                                        <label class="form-check-label" for="day_@day.Value">
                                            @day.Key
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                        
                        <div class="alert alert-warning mt-3">
                            <strong>⚠️ نکته مهم:</strong> با ایجاد برنامه جدید، برنامه قبلی شما به طور خودکار غیرفعال خواهد شد.
                        </div>
                        
                        <button type="submit" class="btn btn-primary w-100 mt-3" id="submitBtn">✅ ایجاد برنامه</button>
                    </form>
                    
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger mt-3">@Model.ErrorMessage</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const checkboxes = document.querySelectorAll('.day-checkbox');
            const sessionsPerWeek = document.getElementById('sessionsPerWeek');
            const selectedCountSpan = document.getElementById('selectedCount');
            const maxSelectSpan = document.getElementById('maxSelect');
            const submitBtn = document.getElementById('submitBtn');
            
            function updateMaxSelect() {
                const max = parseInt(sessionsPerWeek.value);
                maxSelectSpan.textContent = max;
                return max;
            }
            
            function updateSelectedCount() {
                const checked = document.querySelectorAll('.day-checkbox:checked');
                const count = checked.length;
                selectedCountSpan.textContent = count;
                
                const max = parseInt(sessionsPerWeek.value);
                if (count === max) {
                    selectedCountSpan.className = 'badge bg-success';
                    submitBtn.disabled = false;
                    submitBtn.style.opacity = '1';
                    submitBtn.style.cursor = 'pointer';
                } else {
                    selectedCountSpan.className = 'badge bg-danger';
                    submitBtn.disabled = true;
                    submitBtn.style.opacity = '0.5';
                    submitBtn.style.cursor = 'not-allowed';
                }
                
                return count;
            }
            
            function handleCheckboxChange(e) {
                const max = parseInt(sessionsPerWeek.value);
                const checked = document.querySelectorAll('.day-checkbox:checked');
                
                if (e.target.checked && checked.length > max) {
                    e.target.checked = false;
                    alert(`حداکثر می‌توانید ${max} روز تمرینی انتخاب کنید!`);
                }
                updateSelectedCount();
            }
            
            updateMaxSelect();
            updateSelectedCount();
            
            sessionsPerWeek.addEventListener('change', function() {
                const max = updateMaxSelect();
                const checked = document.querySelectorAll('.day-checkbox:checked');
                if (checked.length !== max) {
                    updateSelectedCount();
                }
            });
            
            checkboxes.forEach(cb => {
                cb.addEventListener('change', handleCheckboxChange);
            });
            
            document.getElementById('createPlanForm').addEventListener('submit', function(e) {
                const max = parseInt(sessionsPerWeek.value);
                const checked = document.querySelectorAll('.day-checkbox:checked');
                
                if (checked.length !== max) {
                    e.preventDefault();
                    alert(`شما باید دقیقاً ${max} روز تمرینی انتخاب کنید! (در حال حاضر ${checked.length} روز انتخاب شده)`);
                }
            });
        });
    </script>
}