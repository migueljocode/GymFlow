@page
@model IndexModel
@{
    ViewData["Title"] = "داشبورد";
}

<div class="container">
    <!-- خوش آمدید با نقش -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>خوش آمدید، @Model.Username</h2>
            @if (Model.IsCoach)
            {
                <span class="badge bg-danger fs-6"><i class="fas fa-key"></i> مربی</span>
            }
            else
            {
                <span class="badge bg-info fs-6"><i class="fas fa-dumbbell"></i> کاربر عادی</span>
            }
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <!-- ========== کارت خلاصه وضعیت ========== -->
            @if (Model.IsCoach)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-chart-line"></i> خلاصه وضعیت مربی</h4>
                    </div>
                    <div class="card-body">
                        @if (Model.CoachStats != null)
                        {
                            <div class="row text-center">
                                <div class="col-md-3 col-6 mb-3">
                                    <div class="card bg-success text-white stats-card">
                                        <div class="card-body">
                                            <h3>@Model.CoachStats.TotalClients</h3>
                                            <p class="mb-0">تعداد مشتریان</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 col-6 mb-3">
                                    <div class="card bg-info text-white stats-card">
                                        <div class="card-body">
                                            <h3>@Model.CoachStats.ActiveClients</h3>
                                            <p class="mb-0">مشتریان فعال</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 col-6 mb-3">
                                    <div class="card bg-warning text-white stats-card">
                                        <div class="card-body">
                                            <h3>@Model.CoachStats.TotalWorkoutsThisWeek</h3>
                                            <p class="mb-0">تمرین این هفته</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 col-6 mb-3">
                                    <div class="card bg-danger text-white stats-card">
                                        <div class="card-body">
                                            <h3>@Model.CoachStats.PlansCreated</h3>
                                            <p class="mb-0">برنامه‌های ایجاد شده</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info text-center">در حال بارگذاری آمار...</div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-chart-line"></i> خلاصه وضعیت</h4>
                    </div>
                    <div class="card-body">
                        @if (Model.Stats != null)
                        {
                            <div class="row text-center">
                                <div class="col-md-3 col-6 mb-3">
                                    <div class="card bg-success text-white stats-card">
                                        <div class="card-body">
                                            <h3>@Model.Stats.TotalWorkouts</h3>
                                            <p class="mb-0"><i class="fas fa-dumbbell"></i>  تمرین کل</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 col-6 mb-3">
                                    <div class="card bg-info text-white stats-card">
                                        <div class="card-body">
                                            <h3>@Model.Stats.CurrentStreak</h3>
                                            <p class="mb-0"><i class="fas fa-fire"></i>  روز متوالی</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 col-6 mb-3">
                                    <div class="card bg-warning text-white stats-card">
                                        <div class="card-body">
                                            <h3>@Model.Stats.ConsistencyScore%</h3>
                                            <p class="mb-0"><i class="fas fa-chart-line"></i>  تعهد به تمرین</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-3 col-6 mb-3">
                                    <div class="card bg-danger text-white stats-card">
                                        <div class="card-body">
                                            <h3>@Model.Stats.CurrentWeight.ToString("F1") kg</h3>
                                            <p class="mb-0"><i class="fas fa-weight-scale"></i> وزن فعلی</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-info text-center">در حال بارگذاری اطلاعات...</div>
                        }
                    </div>
                </div>
            }

            <!-- ========== کارت روند وزنی ========== -->
           <!-- ========== کارت روند وزنی ========== -->
            @if (Model.WeightHistory != null && Model.WeightHistory.Any())
            {
                var firstWeight = Model.WeightHistory.First().Weight;
                var lastWeight = Model.WeightHistory.Last().Weight;
                var totalChange = lastWeight - firstWeight;
                var changeClass = totalChange < 0 ? "text-success" : totalChange > 0 ? "text-danger" : "text-muted";
                var changeSign = totalChange > 0 ? "+" : "";
                
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-chart-simple"></i> روند وزنی</h4>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered text-center">
                                <thead class="table-dark">
                                    <tr>
                                        <th>تاریخ</th>
                                        <th>وزن (kg)</th>
                                        <th>درصد چربی</th>
                                        <th>تغییر نسبت به قبلی</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.WeightHistory.Count; i++)
                                    {
                                        var item = Model.WeightHistory[i];
                                        var change = i > 0 ? item.Weight - Model.WeightHistory[i - 1].Weight : 0;
                                        var changeClassRow = change < 0 ? "text-success" : change > 0 ? "text-danger" : "text-muted";
                                        var changeSignRow = change > 0 ? "+" : "";
                                        <tr>
                                            <td>@item.Date.ToString("yyyy/MM/dd")</td>
                                            <td><strong>@item.Weight.ToString("F1")</strong></td>
                                            <td>@(item.BodyFatPercentage?.ToString("F1") ?? "-")</td>
                                            <td class="@changeClassRow">
                                                @if (i > 0)
                                                {
                                                    @($"{changeSignRow}{change:F1}")
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="alert alert-info mt-2">
                            <strong><i class="fas fa-chart-line"></i> خلاصه کلی:</strong><br />
                            از <strong>@firstWeight.ToString("F1") kg</strong> به <strong>@lastWeight.ToString("F1") kg</strong><br />
                            <span class="@changeClass">
                                تغییر کل: @changeSign@(totalChange.ToString("F1")) kg
                            </span>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0"><i class="fas fa-chart-simple"></i> روند وزنی</h4>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info text-center">
                            <p class="mb-0">هنوز وزنی ثبت نشده است.</p>
                            @if (!Model.IsCoach)
                            {
                                <a href="/Progress/Add" class="btn btn-primary mt-2">ثبت وزن جدید</a>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- ========== کارت فعالیت‌های اخیر ========== -->
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-rotate-right"></i> فعالیت‌های اخیر</h4>
                </div>
                <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                    @if (Model.RecentActivities != null && Model.RecentActivities.Any())
                    {
                       @foreach (var activity in Model.RecentActivities)
                        {
                            <div class="d-flex mb-3 align-items-start border-bottom pb-2">
                                <div class="me-3">
                                    @if (activity.Type == "workout")
                                    {
                                        <span class="badge bg-success p-3" style="margin-top: 8px; margin-left: 20px; margin-right: -5px;"><i class="fas fa-dumbbell fa-lg"></i></span>
                                    }
                                    else if (activity.Type == "weight")
                                    {
                                        <span class="badge bg-info p-3" style="margin-top: 8px; margin-left: 20px; margin-right: -5px;"><i class="fas fa-weight-scale fa-lg"></i></span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary p-3" style="margin-top: 8px; margin-left: 20px; margin-right: -5px;"><i class="fas fa-bell fa-lg"></i></span>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-1">
                                        @activity.Title
                                        @if (!string.IsNullOrEmpty(activity.ClientName))
                                        {
                                            <span class="text-muted small"> - @activity.ClientName</span>
                                        }
                                    </h6>
                                    <small class="text-muted d-block">@activity.Description</small>
                                    <small class="text-muted">@activity.Timestamp.ToString("yyyy/MM/dd HH:mm")</small>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-info text-center">
                            <p class="mb-0">هنوز فعالیتی ثبت نشده است.</p>
                            @if (!Model.IsCoach)
                            {
                                <a href="/Workout/Log" class="btn btn-primary mt-2">ثبت تمرین</a>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <!-- ========== کارت برنامه امروز ========== -->
            @if (!Model.IsCoach)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h4 class="mb-0"><i class="fas fa-calendar-day"></i> برنامه امروز</h4>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="text-primary mb-3">@(Model.TodayWorkout?.DayOfWeekPersian ?? DateTime.Now.ToString("dddd", new System.Globalization.CultureInfo("fa-IR")))</h5>
                        @if (Model.TodayWorkout != null)
                        {
                            <p><strong><i class="fas fa-bullseye"></i> عضلات هدف:</strong> @Model.TodayWorkout.TargetMuscles</p>
                            <p><strong><i class="fas fa-clock"></i> مدت زمان:</strong> @Model.TodayWorkout.DurationMinutes دقیقه</p>
                            <p><strong><i class="fas fa-bolt"></i> شدت:</strong> @Model.TodayWorkout.Intensity</p>
                            <a href="/Workout/Log" class="btn btn-success w-100 mt-2"><i class="fas fa-check-circle"></i> ثبت تمرین امروز</a>
                        }
                        else
                        {
                            <div class="text-center">
                                <p class="text-muted"><i class="fas fa-party-horn"></i> امروز تمرین برنامه‌ریزی نشده!</p>
                                <small>از برنامه تمرینی خود لذت ببرید و استراحت کنید</small>
                                <hr />
                                <p class="text-muted small">@(string.IsNullOrEmpty(Model.ActivePlanName) ? "برنامه فعالی ندارید" : $"برنامه فعال: {Model.ActivePlanName}")</p>
                                <a href="/WorkoutPlans" class="btn btn-outline-primary w-100 mt-2">مشاهده برنامه‌ها</a>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- ========== کارت دستاوردها ========== -->
            @if (!Model.IsCoach)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-warning text-white">
                        <h4 class="mb-0"><i class="fas fa-trophy"></i> دستاوردها</h4>
                    </div>
                    <div class="card-body" style="max-height: 300px; overflow-y: auto;">
                        @if (Model.Achievements != null && Model.Achievements.Any())
                        {
                            <ul class="list-unstyled mb-0">
                                @foreach (var ach in Model.Achievements)
                                {
                                    <li class="mb-3">
                                        <div class="d-flex align-items-center">
                                            <span class="fs-3 me-2">@ach.Icon</span>
                                            <div>
                                                <strong>@ach.Name</strong>
                                                <p class="text-muted small mb-0">@ach.Description</p>
                                            </div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-center">
                                <p><i class="fas fa-star"></i> هنوز دستاوردی ندارید</p>
                                <small class="text-muted">با ادامه تمرینات، دستاوردهای جدید کسب کنید!</small>
                            </div>
                        }
                    </div>
                </div>
            }

            <!-- ========== کارت لینک‌های سریع ========== -->
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="fas fa-bolt"></i> لینک‌های سریع</h4>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        @if (Model.IsCoach)
                        {
                            <a href="/Coach/Clients" class="btn btn-outline-primary"><i class="fas fa-users"></i> مشاهده مشتریان</a>
                            <a href="/Reports" class="btn btn-outline-primary"><i class="fas fa-file-pdf"></i> دانلود گزارش PDF</a>
                        }
                        else
                        {
                            <a href="/Workout/Log" class="btn btn-outline-primary"><i class="fas fa-dumbbell"></i> ثبت تمرین جدید</a>
                            <a href="/Progress/Add" class="btn btn-outline-primary"><i class="fas fa-weight-scale"></i> ثبت وزن جدید</a>
                            <a href="/Reports" class="btn btn-outline-primary"><i class="fas fa-file-pdf"></i> دانلود گزارش PDF</a>
                            <a href="/WorkoutPlans" class="btn btn-outline-primary"><i class="fas fa-clipboard-list"></i> مشاهده برنامه‌های تمرینی</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- المنت‌های مخفی برای نمایش Toast -->
@if (TempData["Message"] != null)
{
    <input type="hidden" id="toastMessage" value="@TempData["Message"]" />
    <input type="hidden" id="toastTitle" value="موفقیت ✅" />
    <input type="hidden" id="toastIsError" value="false" />
}
@if (TempData["ErrorMessage"] != null)
{
    <input type="hidden" id="toastMessage" value="@TempData["ErrorMessage"]" />
    <input type="hidden" id="toastTitle" value="خطا ❌" />
    <input type="hidden" id="toastIsError" value="true" />
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var messageElem = document.getElementById('toastMessage');
            if (messageElem && messageElem.value) {
                var titleElem = document.getElementById('toastTitle');
                var isErrorElem = document.getElementById('toastIsError');
                var title = titleElem ? titleElem.value : "اطلاعیه";
                var isError = isErrorElem ? isErrorElem.value === 'true' : false;
                
                if (typeof showToast === 'function') {
                    showToast(messageElem.value, title, isError);
                }
            }
        });
    </script>
}