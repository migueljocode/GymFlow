﻿<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GymFlow</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <style>
        /* reset margins and paddings */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        html, body {
            height: 100%;
            margin: 0;
            padding: 0;
        }
        
        body {
            display: flex;
            flex-direction: column;
            background-color: #f8f9fa;
        }
        
        /* فضای خالی برای navbar ثابت */
        body.has-navbar {
            padding-top: 100px;
        }
        
        main {
            flex: 1 0 auto;
        }
        
        footer {
            flex-shrink: 0;
            background-color: #cbd5e1a9;
            @* border-top: 1px solid #94a3b899; *@
            padding: 1rem 0;
            margin-top: 2rem;
        }
        
        /* Navbar شیشه‌ای */
        .top-bar {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: rgba(15, 25, 45, 0.75);
            backdrop-filter: blur(7.5px);
            -webkit-backdrop-filter: blur(7.5px);
            width: 100%;
            margin: 0;
            padding: 0;
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s ease;
        }
        
        .top-bar .container {
            padding-top: 0.75rem;
            padding-bottom: 0.75rem;
        }
        
        .top-bar .navbar-brand {
            font-weight: 600;
            letter-spacing: 0.5px;
            font-size: 1.35rem;
        }
        
        .top-bar .nav-link {
            transition: all 0.2s ease;
            border-radius: 8px;
            margin: 0 3px;
            padding: 0.5rem 1rem;
            font-size: 0.95rem;
        }
        
        .top-bar .nav-link:hover {
            background: rgba(255, 255, 255, 0.12);
            transform: translateY(-1px);
        }
        
        /* ========================================
           TOAST NOTIFICATION - GLASSMORPHISM STYLE
           ======================================== */

        .toast-container {
            z-index: 1050;
        }

        .toast-container .toast {
            min-width: 320px;
            max-width: 380px;
            border-radius: 20px;
            backdrop-filter: blur(12px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
            direction: rtl;
            overflow: hidden;
        }

        @@keyframes slideInRight {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        @@keyframes slideOutRight {
            from { transform: translateX(0); opacity: 1; }
            to { transform: translateX(100%); opacity: 0; }
        }

        .toast-container .toast {
            animation: slideInRight 0.3s ease forwards;
        }

        .toast-container .toast.hiding {
            animation: slideOutRight 0.3s ease forwards;
        }

        .toast-container .toast-success {
            background: rgba(16, 185, 129, 0.15);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .toast-container .toast-error {
            background: rgba(239, 68, 68, 0.15);
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .toast-container .toast-info {
            background: rgba(59, 130, 246, 0.15);
            border: 1px solid rgba(59, 130, 246, 0.3);
        }

        .toast-container .toast-header {
            padding: 12px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255, 255, 255, 0.1);
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 20px 20px 0 0;
        }

        .toast-container .toast-body {
            padding: 14px 16px;
            font-size: 0.9rem;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 0 0 20px 20px;
        }

        .toast-container .toast-header .btn-close {
            margin: 0;
            order: -1;
            filter: brightness(0) invert(1);
            opacity: 0.7;
        }

        .toast-container .toast-header .btn-close:hover {
            opacity: 1;
        }

        .stats-card {
            transition: transform 0.2s;
        }
        
        .stats-card:hover {
            transform: translateY(-5px);
        }
    </style>
</head>
<body>
    @{
        var userRole = Context.Session.GetString("UserRole");
        var isCoach = userRole == "Coach";
        var username = Context.Session.GetString("Username") ?? "کاربر";
        var isLoginPage = Context.Request.Path.StartsWithSegments("/Login");
        var isRegisterPage = Context.Request.Path.StartsWithSegments("/SignUp");
        var hideNavbar = isLoginPage || isRegisterPage;
    }

    @if (!hideNavbar)
    {
        <nav class="navbar navbar-expand-lg navbar-dark top-bar">
            <div class="container">
                <a class="navbar-brand" href="/"><i class="fas fa-dumbbell"></i> GymFlow</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        @if (isCoach)
                        {
                            <li class="nav-item"><a class="nav-link" href="/"><i class="fas fa-chart-line"></i> داشبورد</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Coach/Clients"><i class="fas fa-users"></i> مشتریان من</a></li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" href="/"><i class="fas fa-chart-line"></i> داشبورد</a></li>
                            <li class="nav-item"><a class="nav-link" href="/WorkoutPlans"><i class="fas fa-clipboard-list"></i> برنامه‌های من</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Workout/Log"><i class="fas fa-dumbbell"></i> ثبت تمرین</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Progress"><i class="fas fa-weight-scale"></i> تاریخچه وزن</a></li>
                            <li class="nav-item"><a class="nav-link" href="/Reports"><i class="fas fa-file-pdf"></i> گزارش‌ها</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" href="/Profile">
                                <i class="fas fa-user-circle"></i> @username
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-danger" href="/Logout">
                                <i class="fas fa-sign-out-alt"></i> خروج
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    }

    <main>
        <div class="container">
            @RenderBody()
        </div>
    </main>

    @if (!hideNavbar)
    {
        <footer>
            <div class="container text-center">
                <span class="text-muted">GymFlow - مدیریت تمرینات بدنسازی © @DateTime.Now.Year</span>
            </div>
        </footer>
    }

    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1050;">
        <div id="liveToast" class="toast toast-info" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4000">
            <div class="toast-header">
                <strong class="me-auto" id="toast-title">اطلاعیه</strong>
                <button type="button" class="btn-close" data-bs-dismiss="toast"></button>
            </div>
            <div class="toast-body" id="toast-message">پیام</div>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    <script>
        @if (!hideNavbar)
        {
            <text>
            document.body.classList.add('has-navbar');
            </text>
        }
        
        function showToast(message, title = "اطلاعیه", isError = false) {
            var toastElement = document.getElementById('liveToast');
            if (!toastElement) return;
            var toastTitle = document.getElementById('toast-title');
            var toastMessage = document.getElementById('toast-message');
            
            toastElement.classList.remove('toast-success', 'toast-error', 'toast-info', 'hiding');
            
            if (isError) {
                toastElement.classList.add('toast-error');
                toastTitle.textContent = "❌ خطا";
            } else if (title === "موفقیت") {
                toastElement.classList.add('toast-success');
                toastTitle.textContent = "✅ موفقیت";
            } else {
                toastElement.classList.add('toast-info');
                toastTitle.textContent = title;
            }
            
            toastMessage.textContent = message;
            
            var toast = new bootstrap.Toast(toastElement, { autohide: true, delay: 4000 });
            
            toastElement.addEventListener('hide.bs.toast', function() {
                toastElement.classList.add('hiding');
            });
            
            toastElement.addEventListener('hidden.bs.toast', function() {
                toastElement.classList.remove('hiding');
            });
            
            toast.show();
        }

        document.addEventListener('DOMContentLoaded', function() {
            var messageElem = document.getElementById('toastMessage');
            var errorElem = document.getElementById('toastError');
            if (messageElem && messageElem.value) {
                showToast(messageElem.value, "موفقیت", false);
            }
            if (errorElem && errorElem.value) {
                showToast(errorElem.value, "خطا", true);
            }
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>