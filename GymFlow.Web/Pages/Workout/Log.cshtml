@page
@model LogModel
@{
    ViewData["Title"] = "ثبت جلسه تمرین";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">💪 ثبت جلسه تمرین</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">تاریخ</label>
                        <input type="date" class="form-control" asp-for="ActualDate" required />
                        <small class="form-text text-muted">تاریخی که تمرین را انجام داده‌اید را وارد کنید</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">مدت زمان (دقیقه)</label>
                        <input type="number" class="form-control" asp-for="DurationMinutes" min="1" max="300" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">حس و حال</label>
                        <select class="form-select" asp-for="Feeling">
                            <option value="">انتخاب کنید...</option>
                            <option value="عالی بود! 💪">عالی بود! 💪</option>
                            <option value="خوب بود 👍">خوب بود 👍</option>
                            <option value="کمی خسته 😴">کمی خسته 😴</option>
                            <option value="زانو درد داشتم">زانو درد داشتم</option>
                        </select>
                    </div>
                    
                    <button type="submit" class="btn btn-success w-100">✅ ثبت تمرین</button>
                </form>
            </div>
        </div>
    </div>
</div>

    <!-- المنت‌های مخفی برای نمایش Toast -->
    @if (TempData["Message"] != null)
    {
        <input type="hidden" id="toastMessage" value="@TempData["Message"]" />
        <input type="hidden" id="toastTitle" value="موفقیت ✅" />
        <input type="hidden" id="toastIsError" value="false" />
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <input type="hidden" id="toastMessage" value="@TempData["ErrorMessage"]" />
        <input type="hidden" id="toastTitle" value="خطا ❌" />
        <input type="hidden" id="toastIsError" value="true" />
    }

    @section Scripts {
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                var messageElem = document.getElementById('toastMessage');
                if (messageElem && messageElem.value) {
                    var titleElem = document.getElementById('toastTitle');
                    var isErrorElem = document.getElementById('toastIsError');
                    var title = titleElem ? titleElem.value : "اطلاعیه";
                    var isError = isErrorElem ? isErrorElem.value === 'true' : false;
                    
                    if (typeof showToast === 'function') {
                        showToast(messageElem.value, title, isError);
                    }
                }
            });
        </script>
    }