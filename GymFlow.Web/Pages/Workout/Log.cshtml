@page
@model LogModel
@{
    ViewData["Title"] = "ثبت تمرین امروز";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h4 class="mb-0">💪 ثبت جلسه تمرین</h4>
            </div>
            <div class="card-body">
                <form method="post">
                    <div class="mb-3">
                        <label class="form-label">تاریخ</label>
                        <input type="date" class="form-control" asp-for="ActualDate" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">مدت زمان (دقیقه)</label>
                        <input type="number" class="form-control" asp-for="DurationMinutes" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">حس و حال</label>
                        <select class="form-select" asp-for="Feeling">
                            <option value="">انتخاب کنید...</option>
                            <option value="عالی بود! 💪">عالی بود! 💪</option>
                            <option value="خوب بود 👍">خوب بود 👍</option>
                            <option value="کمی خسته 😴">کمی خسته 😴</option>
                            <option value="زانو درد داشتم">زانو درد داشتم</option>
                        </select>
                    </div>
                    
                    <button type="submit" class="btn btn-success w-100">✅ ثبت تمرین</button>
                </form>
                
                @if (!string.IsNullOrEmpty(Model.Message))
                {
                    <div class="alert alert-info mt-3">@Model.Message</div>
                }
            </div>
        </div>
    </div>
</div>